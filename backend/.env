PORT=5000
NODE_ENV=development

# Database Configuration (Prisma)
# Default is SQLite for instant local development.
# To use PostgreSQL or MySQL:
# 1. Update schema.prisma provider to "postgresql" or "mysql"
# 2. Update this DATABASE_URL connection string (e.g. postgresql://user:password@localhost:5432/ayurmilan)
DATABASE_URL="file:./dev.db"

# JWT Secret for Admin Session Verification
JWT_SECRET=ayurmilan2026_super_secret_jwt_key_987654321

# Default Seeding Credentials
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=ayurmilan2026


# SMTP Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AyurMilan <no-reply@ayurmilan.org>"
